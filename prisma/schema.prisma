generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("POSTGRES_PRISMA_URL") // uses connection pooling
  directUrl = env("POSTGRES_URL_NON_POOLING") // uses a direct connection
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  password      String?
  image         String?
  phone         String?
  role          String    @default("CUSTOMER")
  age           Int?
  interests     String?
  isOnboarded   Boolean   @default(false)
  lastIp        String?
  lastLogin     DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  accounts      Account[]
  orders        Order[]
  sessions      Session[]
  vendorProfile Vendor?
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Vendor {
  id               String       @id @default(cuid())
  userId           String       @unique
  storeName        String
  storeDescription String?
  bankStatementUrl String?
  commercialRegUrl String?
  status           String       @default("PENDING")
  commissionType   String       @default("PERCENTAGE")
  commissionRate   Float        @default(10.0)
  fixedFee         Float        @default(0.0)
  subscriptionFee  Float        @default(0.0)
  location         String?
  shippingModel    String       @default("VENDOR_PACKS") // VENDOR_PACKS | MERSAL_HANDLES
  phone            String?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  orderItems       OrderItem[]
  products         Product[]
  user             User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  withdrawals      Withdrawal[]
}

model Product {
  id            String      @id @default(cuid())
  title         String
  description   String
  price         Float
  stock         Int         @default(0)
  images        String?
  sizes         String?
  colors        String?
  status        String      @default("PENDING")
  vendorId      String
  categoryId    String?
  purchaseCount Int         @default(0)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  orderItems    OrderItem[]
  category      Category?   @relation(fields: [categoryId], references: [id])
  vendor        Vendor      @relation(fields: [vendorId], references: [id])
}

model Category {
  id       String    @id @default(cuid())
  name     String    @unique
  icon     String?
  products Product[]
}

model Order {
  id                String      @id @default(cuid())
  customerId        String
  status            String      @default("PENDING_APPROVAL")
  // Statuses: PENDING_APPROVAL | APPROVED | PACKING | SHIPPED | DELIVERED | REJECTED
  totalAmount       Float
  shippingCost      Float       @default(0)
  paymentMethod     String      // COD | BANK_TRANSFER
  city              String
  district          String
  street            String
  phone             String
  customerEmail     String?
  customerName      String?
  notes             String?     // ملاحظات العميل
  // Payment verification
  paymentScreenshot String?     // رابط صورة الإيصال
  paymentVerified   Boolean     @default(false)
  paymentNote       String?     // ملاحظة الـ AI
  // Tracking
  trackingLat       Float?      // موقع المندوب
  trackingLng       Float?
  trackingNumber    String?     // رقم تتبع شركة الشحن
  trackingUrl       String?     // رابط تتبع يدوي (أو خارجي)
  estimatedDays     Int?        // عدد أيام التوصيل المتوقعة
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
  customer          User        @relation(fields: [customerId], references: [id])
  items             OrderItem[]
  driverId          String?
  driver            DeliveryDriver? @relation(fields: [driverId], references: [id])
}

model OrderItem {
  id          String  @id @default(cuid())
  orderId     String
  productId   String
  vendorId    String
  quantity    Int
  priceAtTime Float
  size        String?
  color       String?
  vendor      Vendor  @relation(fields: [vendorId], references: [id])
  product     Product @relation(fields: [productId], references: [id])
  order       Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model Withdrawal {
  id        String   @id @default(cuid())
  vendorId  String
  amount    Float
  status    String   @default("PENDING")
  createdAt DateTime @default(now())
  vendor    Vendor   @relation(fields: [vendorId], references: [id])
}

model Settings {
  id                 String  @id @default("global")
  exchangeRate       Float   @default(1.0)
  baseCurrency       String  @default("SDG")
  platformCommission Float   @default(10.0)
  maintenanceMode    Boolean @default(false)
  maintenanceMessage String  @default("هناك خطأ تقني يجري إصلاحه")
  // Payment Settings
  codEnabled         Boolean @default(true)
  codExtraFee        Float   @default(2000)
  codCitiesOnly      String  @default("الخرطوم") // مدن الدفع عند الاستلام
  bankTransferEnabled Boolean @default(true)
  bankName           String  @default("")
  bankAccountNumber  String  @default("")
  bankAccountName    String  @default("")
}

// ── New Models ──────────────────────────────────────────

model Employee {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  role      String   // PACKING | SHIPPING | CUSTOMER_SERVICE | ADMIN
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
}

model DeliveryZone {
  id       String  @id @default(cuid())
  name     String  // اسم المنطقة (شمبات، بحري...)
  city     String  // المدينة (الخرطوم، أم درمان...)
  fee      Float   // رسوم التوصيل بالجنيه السوداني
  isActive Boolean @default(true)
}

model ShippingProvider {
  id        String   @id @default(cuid())
  name      String   // اسم الشركة
  apiKey    String   // API Key المشفّرة
  baseUrl   String   // رابط الـ API
  isActive  Boolean  @default(false)
  createdAt DateTime @default(now())
}

model DeliveryDriver {
  id          String   @id @default(cuid())
  name        String
  phone       String
  vehicleType String   // e.g. MOTORCYCLE, CAR, VAN
  isActive    Boolean  @default(true)
  orders      Order[]
  createdAt   DateTime @default(now())
}
